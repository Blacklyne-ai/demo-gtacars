---
import Layout from '../../layouts/Layout.astro';
import CarCard from '../../components/CarCard.astro';
import { getCars } from '../../lib/cars';
import { Heart, ArrowRight } from '@lucide/astro';

const all = await getCars();
---
<Layout title="Saved cars — GTA Cars Dubai" description="Your shortlisted cars at GTA Cars Dubai.">
  <section class="border-b border-ivory/10 bg-coal pb-10 pt-[calc(var(--nav-h)+3rem)]">
    <div class="lux-wide">
      <p class="eyebrow mb-4">Your shortlist</p>
      <h1 class="display-2 text-ivory">Saved cars</h1>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-mist">The cars you’ve saved, kept on this device. Tap the heart on any car to add or remove it.</p>
    </div>
  </section>

  <section class="bg-ink py-12 sm:py-16">
    <div class="lux-wide">
      <h2 class="sr-only">Your saved cars</h2>
      <!-- ★ Mobile: one car per row -->
      <div data-wish-grid class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {all.map((car) => (
          <div data-wish-item data-id={car.slug} class="hidden"><CarCard car={car} /></div>
        ))}
      </div>

      <div data-wish-empty class="py-16 text-center">
        <span class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full border border-ivory/12 text-gold"><Heart class="h-7 w-7" /></span>
        <p class="mt-6 font-display text-2xl text-ivory">No saved cars yet.</p>
        <p class="mt-3 text-sm text-mist">Browse the showroom and tap the heart to build your shortlist.</p>
        <a href="/our-cars" class="btn-gold mt-8 px-8 py-3.5">Browse our cars <ArrowRight class="h-4 w-4" /></a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const WK = 'gta-wishlist';
  const read = (): string[] => { try { return JSON.parse(localStorage.getItem(WK) || '[]'); } catch { return []; } };
  const grid = document.querySelector('[data-wish-grid]') as HTMLElement;
  const empty = document.querySelector('[data-wish-empty]') as HTMLElement;
  function render() {
    const ids = read();
    let shown = 0;
    document.querySelectorAll('[data-wish-item]').forEach((el) => {
      const on = ids.includes((el as HTMLElement).dataset.id || '');
      el.classList.toggle('hidden', !on);
      if (on) shown++;
    });
    empty.classList.toggle('hidden', shown > 0);
    grid.classList.toggle('hidden', shown === 0);
  }
  render();
  document.addEventListener('wishlist:change', render);
</script>
