---
import Layout from '../../layouts/Layout.astro';
import CarCard from '../../components/CarCard.astro';
import { getCars, similar, fmtAED, fmtKm, type Car } from '../../lib/cars';
import { contact } from '../../data/site';
import { Heart, MessageCircle, Phone, ArrowLeft, Landmark, ArrowLeftRight, Gauge, Cog, Cylinder, Zap, Fuel, Palette, DoorOpen, MapPin, ShieldCheck, FileCheck, Wrench, Calendar, ChevronLeft, ChevronRight, Expand, X } from '@lucide/astro';

export async function getStaticPaths() {
  const all = await getCars();
  return all.map((car) => ({ params: { slug: car.slug }, props: { car, all } }));
}
const { car, all } = Astro.props as { car: Car; all: Car[] };
const sims = similar(all, car, 3);

const enquiry = `Hi GTA Cars, I'm interested in the ${car.year ?? ''} ${car.name} (${fmtAED(car.priceAed)}). Is it still available?`;
const waHref = `https://wa.me/971585121860?text=${encodeURIComponent(enquiry)}`;

const specRows = [
  car.year && { icon: 'Calendar', label: 'Year', value: String(car.year) },
  car.specs.mileageKm != null && { icon: 'Gauge', label: 'Mileage', value: fmtKm(car.specs.mileageKm) },
  car.specs.transmission && { icon: 'Cog', label: 'Transmission', value: car.specs.transmission },
  car.bodyType && car.bodyType !== 'Other' && { icon: 'Fuel', label: 'Body type', value: car.bodyType },
  car.specs.cylinders && { icon: 'Cylinder', label: 'Cylinders', value: car.specs.cylinders },
  car.specs.horsepower && { icon: 'Zap', label: 'Power', value: car.specs.horsepower },
  car.specs.fuelType && { icon: 'Fuel', label: 'Fuel', value: car.specs.fuelType },
  car.specs.colour && { icon: 'Palette', label: 'Colour', value: car.specs.colour },
  car.specs.doors && { icon: 'DoorOpen', label: 'Doors', value: car.specs.doors },
  car.specs.regional && { icon: 'MapPin', label: 'Specs', value: car.specs.regional },
  car.specs.warranty && { icon: 'ShieldCheck', label: 'Warranty', value: car.specs.warranty },
  car.specs.serviceHistory && { icon: 'FileCheck', label: 'Service history', value: car.specs.serviceHistory },
  car.specs.serviceContract && { icon: 'Wrench', label: 'Service pack', value: car.specs.serviceContract },
].filter(Boolean) as { icon: string; label: string; value: string }[];
const icons: any = { Gauge, Cog, Cylinder, Zap, Fuel, Palette, DoorOpen, MapPin, ShieldCheck, FileCheck, Wrench, Calendar };
---
<Layout title={`${car.title} — GTA Cars Dubai`} description={car.description}>
  <article class="pt-[calc(var(--nav-h)+2rem)]">
    <div class="lux-wide">
      <a href="/our-cars" class="inline-flex items-center gap-2 text-[0.74rem] font-medium uppercase tracking-[0.14em] text-mist transition-colors hover:text-gold"><ArrowLeft class="h-4 w-4" />All cars</a>
    </div>

    <div class="lux-wide mt-6 grid gap-10 lg:grid-cols-[1.5fr_1fr] lg:gap-14">
      <!-- Gallery -->
      <div data-gallery data-count={car.images.length}>
        <div class="group relative overflow-hidden rounded-2xl border border-ivory/10 bg-coal">
          <button data-zoom class="block w-full cursor-zoom-in" aria-label="Enlarge photo">
            <img data-main src={car.images[0]} alt={car.name} width="1400" height="1000" fetchpriority="high" decoding="async" class="aspect-[7/5] w-full object-cover" />
          </button>
          {car.sold && <span class="absolute left-4 top-4 rounded-full bg-[rgb(12,12,13)]/85 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-gold-lite ring-1 ring-gold/40 backdrop-blur">Sold</span>}
          <span class="pointer-events-none absolute right-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-ink/60 px-3 py-1.5 text-[0.66rem] font-medium text-ivory/85 backdrop-blur"><Expand class="h-3.5 w-3.5" /><span data-counter>1</span>/{car.images.length}</span>
          {car.images.length > 1 && (
            <>
              <button data-prev class="absolute left-3 top-1/2 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-ink/55 text-ivory backdrop-blur transition-all hover:bg-ink/80 hover:text-gold focus:opacity-100 sm:opacity-0 sm:group-hover:opacity-100" aria-label="Previous photo"><ChevronLeft class="h-5 w-5" /></button>
              <button data-next class="absolute right-3 top-1/2 inline-flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-full bg-ink/55 text-ivory backdrop-blur transition-all hover:bg-ink/80 hover:text-gold focus:opacity-100 sm:opacity-0 sm:group-hover:opacity-100" aria-label="Next photo"><ChevronRight class="h-5 w-5" /></button>
            </>
          )}
        </div>
        {car.images.length > 1 && (
          <div class="no-scrollbar mt-3 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-1">
            {car.images.map((img, i) => (
              <button data-thumb data-i={i} data-src={img} class:list={['w-24 shrink-0 snap-start overflow-hidden rounded-lg border bg-coal transition-colors sm:w-28', i === 0 ? 'border-gold' : 'border-ivory/10 hover:border-ivory/40']} aria-label={`Photo ${i + 1}`}>
                <img src={img} alt={`${car.name} photo ${i + 1}`} width="240" height="170" loading={i < 6 ? 'eager' : 'lazy'} decoding="async" class="aspect-[4/3] w-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Summary / CTA -->
      <aside class="lg:sticky lg:top-[calc(var(--nav-h)+1.5rem)] lg:self-start">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-gold-deep">{car.brand}{car.year ? ` · ${car.year}` : ''}</p>
        <h1 class="mt-2 font-display text-[1.7rem] font-bold leading-tight text-ivory">{car.name}</h1>

        <div class="mt-5 flex items-end gap-4 border-y border-ivory/10 py-5">
          <div>
            <p class="price-aed font-display text-3xl font-bold text-ivory">{fmtAED(car.priceAed)}</p>
            {car.monthlyAed && <p class="mt-1 text-sm text-mist">from AED {car.monthlyAed.toLocaleString('en-US')}/month</p>}
          </div>
          <button data-wish data-id={car.slug} class="ml-auto inline-flex h-11 w-11 items-center justify-center rounded-full border border-ivory/15 text-ivory/80 transition-colors hover:border-gold/50 hover:text-gold" aria-label={`Save ${car.name}`} aria-pressed="false"><Heart class="h-5 w-5" /></button>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <a href={waHref} target="_blank" rel="noopener" class="btn-gold py-4"><MessageCircle class="h-4 w-4" /> Enquire on WhatsApp</a>
          <a href={contact.phonePrimaryHref} class="btn-primary py-4"><Phone class="h-4 w-4" /> Call {contact.phonePrimary}</a>
        </div>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <a href="/finance" class="card flex items-center gap-2.5 px-4 py-3.5 text-sm text-ivory/85 transition-colors hover:border-gold/40 hover:text-gold"><Landmark class="h-4 w-4 text-gold" /> Apply for finance</a>
          <a href="/part-exchange" class="card flex items-center gap-2.5 px-4 py-3.5 text-sm text-ivory/85 transition-colors hover:border-gold/40 hover:text-gold"><ArrowLeftRight class="h-4 w-4 text-gold" /> Part exchange?</a>
        </div>
        <p class="mt-5 text-xs leading-relaxed text-faint">Inspection, RTA ownership transfer and secure bank-transfer payment — all handled under one roof.</p>
      </aside>
    </div>

    <!-- Specs + description -->
    <div class="lux-wide mt-16 grid gap-12 lg:grid-cols-[1.5fr_1fr] lg:gap-14">
      <div>
        <h2 class="font-display text-xl font-semibold text-ivory">Specifications</h2>
        <dl class="mt-6 grid grid-cols-1 gap-px overflow-hidden rounded-2xl border border-ivory/10 bg-ivory/10 sm:grid-cols-2">
          {specRows.map((r) => {
            const Icon = icons[r.icon] || Gauge;
            return (
              <div class="flex items-center gap-3.5 bg-graphite px-5 py-4">
                <Icon class="h-4 w-4 shrink-0 text-gold/80" />
                <dt class="w-28 shrink-0 text-[0.74rem] uppercase tracking-[0.1em] text-faint">{r.label}</dt>
                <dd class="text-sm font-medium text-ivory">{r.value}</dd>
              </div>
            );
          })}
        </dl>
      </div>
      <div>
        <h2 class="font-display text-xl font-semibold text-ivory">About this car</h2>
        <p class="mt-6 text-sm leading-relaxed text-mist">{car.description}</p>
        <p class="mt-4 text-sm leading-relaxed text-mist">{car.title}.</p>
      </div>
    </div>

    <!-- Similar -->
    {sims.length > 0 && (
      <section class="mt-20 border-t border-ivory/10 bg-coal py-16 sm:py-20">
        <div class="lux-wide">
          <h2 class="display-3 text-ivory">Similar cars</h2>
          <!-- ★ Mobile: one per row -->
          <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {sims.map((c) => <CarCard car={c} />)}
          </div>
        </div>
      </section>
    )}
  </article>

  <!-- Lightbox -->
  <div data-lightbox class="lightbox">
    <button data-lb-close class="absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-graphite/80 text-ivory ring-1 ring-ivory/15 transition-colors hover:text-gold" aria-label="Close"><X class="h-5 w-5" /></button>
    <button data-lb-prev class="absolute left-3 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-graphite/70 text-ivory ring-1 ring-ivory/15 transition-colors hover:text-gold sm:left-6" aria-label="Previous"><ChevronLeft class="h-6 w-6" /></button>
    <img data-lb-img src={car.images[0]} alt={car.name} />
    <button data-lb-next class="absolute right-3 top-1/2 inline-flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-graphite/70 text-ivory ring-1 ring-ivory/15 transition-colors hover:text-gold sm:right-6" aria-label="Next"><ChevronRight class="h-6 w-6" /></button>
  </div>
</Layout>

<script is:inline define:vars={{ images: car.images }}>
  (() => {
    const main = document.querySelector('[data-main]');
    const thumbs = Array.from(document.querySelectorAll('[data-thumb]'));
    const counter = document.querySelector('[data-counter]');
    const lb = document.querySelector('[data-lightbox]');
    const lbImg = document.querySelector('[data-lb-img]');
    let idx = 0;

    function setActive(i) {
      idx = (i + images.length) % images.length;
      const src = images[idx];
      if (main) main.src = src;
      if (counter) counter.textContent = String(idx + 1);
      thumbs.forEach((t, j) => {
        t.classList.toggle('border-gold', j === idx);
        t.classList.toggle('border-ivory/10', j !== idx);
      });
      thumbs[idx]?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      if (lb?.classList.contains('is-open') && lbImg) lbImg.src = src;
    }

    thumbs.forEach((t, i) => t.addEventListener('click', () => setActive(i)));
    document.querySelector('[data-prev]')?.addEventListener('click', () => setActive(idx - 1));
    document.querySelector('[data-next]')?.addEventListener('click', () => setActive(idx + 1));

    // Lightbox
    const openLb = () => { if (lbImg) lbImg.src = images[idx]; lb?.classList.add('is-open'); document.body.style.overflow = 'hidden'; };
    const closeLb = () => { lb?.classList.remove('is-open'); document.body.style.overflow = ''; };
    document.querySelector('[data-zoom]')?.addEventListener('click', openLb);
    document.querySelector('[data-lb-close]')?.addEventListener('click', closeLb);
    document.querySelector('[data-lb-prev]')?.addEventListener('click', () => setActive(idx - 1));
    document.querySelector('[data-lb-next]')?.addEventListener('click', () => setActive(idx + 1));
    lb?.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', (e) => {
      if (!lb?.classList.contains('is-open')) return;
      if (e.key === 'Escape') closeLb();
      if (e.key === 'ArrowLeft') setActive(idx - 1);
      if (e.key === 'ArrowRight') setActive(idx + 1);
    });
  })();
</script>
