---
import Layout from '../layouts/Layout.astro';
import LeadForm from '../components/LeadForm.astro';
import SpecialistCards from '../components/SpecialistCards.astro';
import { sell, contact } from '../data/site';
import { Check, MessageCircle, Phone, ArrowRight } from '@lucide/astro';
---
<Layout title="Sell Your Car Today — GTA Cars Dubai" description={sell.heroBody}>
  <!-- Hero band -->
  <section class="relative overflow-hidden border-b border-ivory/10 bg-coal pb-16 pt-[calc(var(--nav-h)+3.5rem)]">
    <div class="lux-wide grid gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-20">
      <div>
        <p class="eyebrow mb-4">We buy any car</p>
        <h1 class="display-1 text-ivory">{sell.heroTitle}</h1>
        <p class="mt-7 max-w-xl text-lg leading-relaxed text-mist">{sell.heroBody}</p>
        <ul class="mt-9 grid gap-3 sm:grid-cols-2">
          {sell.bullets.map((b) => (
            <li class="flex items-start gap-3 text-sm text-ivory/90">
              <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gold/15 text-gold"><Check class="h-3 w-3" /></span>{b}
            </li>
          ))}
        </ul>
      </div>
      <div class="lg:pl-4">
        <div class="card p-6 shadow-lift sm:p-8">
          <h2 class="font-display text-xl font-semibold text-ivory">Get your free valuation</h2>
          <p class="mt-1.5 text-sm text-mist">Fill in your vehicle details and our purchasing team will be in touch.</p>
          <div class="mt-6">
            <LeadForm fields={sell.formFields} submitLabel="Get my offer" formName="sell" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specialists -->
  <section class="bg-ink py-16 sm:py-20">
    <div class="lux-wide">
      <p class="eyebrow mb-3" data-reveal>Or contact our car buying specialists</p>
      <h2 class="display-3 text-ivory" data-reveal>Talk to a person, today.</h2>
      <div class="mt-10"><SpecialistCards /></div>
    </div>
  </section>

  <!-- Process -->
  <section class="border-y border-ivory/10 bg-coal py-20 sm:py-28">
    <div class="lux-wide">
      <div class="max-w-2xl">
        <p class="eyebrow mb-4" data-reveal>What’s the process?</p>
        <h2 class="display-2 text-ivory" data-lines>From your driveway to paid, in four steps.</h2>
      </div>
      <div class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-ivory/10 bg-ivory/10 sm:grid-cols-2 lg:grid-cols-4">
        {sell.process.map((step, i) => (
          <div class="flex flex-col bg-graphite p-7" data-reveal data-delay={i * 70}>
            <span class="price-aed font-display text-3xl font-bold text-gold-deep">{String(i + 1).padStart(2, '0')}</span>
            <p class="mt-5 text-sm leading-relaxed text-ivory/85">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why GTA -->
  <section class="bg-ink py-20 sm:py-28">
    <div class="lux-wide grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <div>
        <p class="eyebrow mb-4" data-reveal>Why GTA Cars</p>
        <h2 class="display-2 text-ivory" data-lines>Reputation, not pressure.</h2>
        <p class="mt-6 text-base leading-relaxed text-mist" data-reveal>You are under no obligation. Selling your car to us is completely free and entirely up to you.</p>
      </div>
      <ul class="grid gap-x-10 gap-y-5 sm:grid-cols-2">
        {sell.why.map((w, i) => (
          <li class="flex items-start gap-3 text-sm leading-relaxed text-ivory/85" data-reveal data-delay={i * 40}>
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-gold"></span>{w}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Closer -->
  <section class="border-t border-ivory/10 bg-coal py-24 text-center sm:py-32">
    <div class="lux-narrow">
      <p class="eyebrow mb-5" data-reveal>{sell.closer}</p>
      <h2 class="display-2 text-ivory" data-lines>{sell.closerSub}</h2>
      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row" data-reveal>
        <a href="#" onclick="document.querySelector('[data-leadform]')?.scrollIntoView({behavior:'smooth'});return false;" class="btn-gold px-8 py-4">Sell your car now <ArrowRight class="h-4 w-4" /></a>
        <a href={contact.whatsapp} target="_blank" rel="noopener" class="btn-primary px-8 py-4"><MessageCircle class="h-4 w-4" /> WhatsApp</a>
        <a href={contact.phonePrimaryHref} class="btn-dark px-8 py-4"><Phone class="h-4 w-4" /> Call us</a>
      </div>
    </div>
  </section>
</Layout>
