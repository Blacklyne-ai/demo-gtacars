---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import StatsBand from '../components/StatsBand.astro';
import CarCard from '../components/CarCard.astro';
import LeadForm from '../components/LeadForm.astro';
import SpecialistCards from '../components/SpecialistCards.astro';
import { getCars, liveCars } from '../lib/cars';
import { sell, services, contact, site } from '../data/site';
import { ArrowRight, ArrowUpRight, Check, MessageCircle, Phone, Mail, Clock, MapPin, Car, Tag, Handshake, ArrowLeftRight, Landmark, ClipboardCheck } from '@lucide/astro';
const icons: any = { Car, Tag, Handshake, ArrowLeftRight, Landmark, ClipboardCheck };

const all = await getCars();
const live = liveCars(all);
// Curated, one premium car per brand for an airy 8-up teaser grid
const fleet = [...live].sort((a, b) => (b.priceAed ?? 0) - (a.priceAed ?? 0))
  .filter((c, i, arr) => arr.findIndex((x) => x.brand === c.brand) === i)
  .slice(0, 8);

const heroImg = '/images/site/dubai-hero.webp';
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(contact.mapQuery)}&output=embed`;
---
<Layout>
  <Hero image={heroImg} alt="Dubai skyline at golden hour" />

  <!-- ───────────── SELL YOUR CAR (focus) ───────────── -->
  <section id="sell" class="bg-ink py-24 sm:py-32">
    <div class="lux-wide">
      <div class="grid gap-14 lg:grid-cols-[1fr_1.05fr] lg:items-start lg:gap-24">
        <div>
          <p class="eyebrow mb-5" data-reveal>We buy any car</p>
          <h2 class="display-2 text-ivory" data-lines>Sell your car today.</h2>
          <p class="mt-7 max-w-xl text-lg leading-relaxed text-mist" data-reveal>{sell.heroBody}</p>
          <ul class="mt-10 grid gap-x-8 gap-y-4 sm:grid-cols-2">
            {sell.bullets.map((b, i) => (
              <li class="flex items-start gap-3 text-[0.95rem] text-ivory/90" data-reveal data-delay={i * 60}>
                <span class="mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full bg-gold/15 text-gold-deep"><Check class="h-2.5 w-2.5" /></span>{b}
              </li>
            ))}
          </ul>
        </div>
        <div data-reveal>
          <div class="rounded-3xl border border-ivory/10 bg-graphite p-7 shadow-lift sm:p-9">
            <h3 class="font-display text-2xl font-medium text-ivory">Get your free valuation</h3>
            <p class="mt-2 text-sm text-mist">No obligation. No hidden fees. We buy any car.</p>
            <div class="mt-7"><LeadForm fields={sell.formFields} submitLabel="Get my offer" formName="sell-home" /></div>
          </div>
        </div>
      </div>

      <div class="mt-16 border-t border-ivory/10 pt-12">
        <p class="eyebrow mb-6" data-reveal>Or speak to our car-buying specialists</p>
        <SpecialistCards cols={3} />
      </div>
    </div>
  </section>

  <!-- ───────────── FLEET — Pick your car ───────────── -->
  <section id="fleet" class="border-t border-ivory/10 bg-coal py-24 sm:py-32">
    <div class="lux-wide">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-xl">
          <p class="eyebrow mb-5" data-reveal>The showroom</p>
          <h2 class="display-2 text-ivory" data-lines>Find your next car.</h2>
        </div>
        <a href="/our-cars" class="link-arrow" data-reveal>All {live.length} cars <ArrowRight class="h-4 w-4" /></a>
      </div>

      <!-- ★ Mobile: one car per row -->
      <div class="mt-14 grid grid-cols-1 gap-x-7 gap-y-12 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {fleet.map((car, i) => <CarCard car={car} eager={i < 4} />)}
      </div>

      <div class="mt-16 flex justify-center" data-reveal>
        <a href="/our-cars" class="btn-dark px-9 py-4 text-sm">Browse the full showroom <ArrowUpRight class="h-4 w-4" /></a>
      </div>
    </div>
  </section>

  <!-- ───────────── CINEMATIC STATS BAND ───────────── -->
  <StatsBand />

  <!-- ───────────── PROCESS ───────────── -->
  <section class="bg-ink py-24 sm:py-32">
    <div class="lux-wide">
      <div class="max-w-2xl">
        <p class="eyebrow mb-5" data-reveal>How selling works</p>
        <h2 class="display-2 text-ivory" data-lines>From your driveway to paid, in four steps.</h2>
      </div>
      <div class="mt-16 grid gap-x-10 gap-y-12 sm:grid-cols-2 lg:grid-cols-4">
        {sell.process.map((step, i) => (
          <div class="relative" data-reveal data-delay={i * 70}>
            <span class="font-display text-5xl font-normal text-gold/70">{String(i + 1).padStart(2, '0')}</span>
            <div class="mt-4 h-px w-10 bg-gold/40"></div>
            <p class="mt-5 text-[0.95rem] leading-relaxed text-mist">{step}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────── SERVICES ───────────── -->
  <section class="border-t border-ivory/10 bg-coal py-24 sm:py-32">
    <div class="lux-wide">
      <div class="max-w-2xl">
        <p class="eyebrow mb-5" data-reveal>Everything under one roof</p>
        <h2 class="display-2 text-ivory" data-lines>One showroom, every step handled.</h2>
        <p class="mt-6 text-base leading-relaxed text-mist" data-reveal>{site.about}</p>
      </div>
      <div class="mt-14 grid gap-px overflow-hidden rounded-3xl border border-ivory/10 bg-ivory/10 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s, i) => {
          const Icon = icons[s.icon];
          return (
            <a href={s.href} class="group flex flex-col gap-5 bg-ink p-8 transition-colors hover:bg-graphite" data-reveal data-delay={i * 50}>
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-full bg-gold/12 text-gold-deep"><Icon class="h-5 w-5" /></span>
              <div>
                <h3 class="font-display text-xl font-medium text-ivory">{s.title}</h3>
                <p class="mt-2.5 text-sm leading-relaxed text-mist">{s.body}</p>
              </div>
              <span class="mt-auto inline-flex items-center gap-1.5 text-[0.7rem] font-medium uppercase tracking-[0.16em] text-gold-deep opacity-0 transition-opacity group-hover:opacity-100">Learn more <ArrowRight class="h-3.5 w-3.5" /></span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ───────────── LET'S TALK + MAP ───────────── -->
  <section class="bg-ink py-24 sm:py-32">
    <div class="lux-wide grid gap-14 lg:grid-cols-[1fr_1.15fr] lg:items-center lg:gap-20">
      <div>
        <p class="eyebrow mb-5" data-reveal>Let’s talk</p>
        <h2 class="display-2 text-ivory" data-lines>Ready when you are.</h2>
        <p class="mt-6 max-w-md text-base leading-relaxed text-mist" data-reveal>One of our experts will be delighted to answer any questions you may have. So please get in touch.</p>
        <div class="mt-8 grid gap-3 sm:grid-cols-2" data-reveal>
          <a href={contact.phonePrimaryHref} class="group flex items-center gap-3.5 rounded-2xl border border-ivory/10 bg-graphite p-4 shadow-soft transition-colors hover:border-gold/40">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gold/12 text-gold-deep"><Phone class="h-5 w-5" /></span>
            <span><span class="block text-[0.66rem] uppercase tracking-[0.14em] text-faint">Call</span><span class="block text-sm font-medium text-ivory">{contact.phonePrimary}</span></span>
          </a>
          <a href={contact.whatsapp} target="_blank" rel="noopener" class="group flex items-center gap-3.5 rounded-2xl border border-ivory/10 bg-graphite p-4 shadow-soft transition-colors hover:border-gold/40">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gold/12 text-gold-deep"><MessageCircle class="h-5 w-5" /></span>
            <span><span class="block text-[0.66rem] uppercase tracking-[0.14em] text-faint">WhatsApp</span><span class="block text-sm font-medium text-ivory">{contact.whatsappNumber}</span></span>
          </a>
          <a href={contact.emailHref} class="group flex items-center gap-3.5 rounded-2xl border border-ivory/10 bg-graphite p-4 shadow-soft transition-colors hover:border-gold/40">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gold/12 text-gold-deep"><Mail class="h-5 w-5" /></span>
            <span><span class="block text-[0.66rem] uppercase tracking-[0.14em] text-faint">Email</span><span class="block text-sm font-medium text-ivory">{contact.email}</span></span>
          </a>
          <div class="flex items-center gap-3.5 rounded-2xl border border-ivory/10 bg-graphite p-4 shadow-soft">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gold/12 text-gold-deep"><Clock class="h-5 w-5" /></span>
            <span><span class="block text-[0.66rem] uppercase tracking-[0.14em] text-faint">Open</span><span class="block text-sm font-medium text-ivory">{contact.hours}</span></span>
          </div>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl border border-ivory/10 shadow-lift" data-reveal>
        <iframe src={mapSrc} title="GTA Cars — Al Quoz, Dubai" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          class="h-full min-h-[360px] w-full lg:min-h-[460px]" style="border:0"></iframe>
      </div>
    </div>
  </section>
</Layout>
