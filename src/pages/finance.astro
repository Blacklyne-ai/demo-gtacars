---
import Layout from '../layouts/Layout.astro';
import LeadForm from '../components/LeadForm.astro';
import { finance, letsTalk, contact } from '../data/site';
import { Check, MessageCircle, ArrowRight, Landmark } from '@lucide/astro';
---
<Layout title="Finance Your Car — GTA Cars Dubai" description={finance.body[0]}>
  <section class="relative overflow-hidden border-b border-ivory/10 bg-coal pb-16 pt-[calc(var(--nav-h)+3.5rem)]">
    <div class="lux-wide grid gap-12 lg:grid-cols-[1fr_1.05fr] lg:gap-20">
      <div>
        <p class="eyebrow mb-4 inline-flex items-center gap-2"><Landmark class="h-4 w-4" /> Financing</p>
        <h1 class="display-1 text-ivory">{finance.heroTitle}</h1>
        {finance.body.map((p) => <p class="mt-6 max-w-xl text-base leading-relaxed text-mist">{p}</p>)}
      </div>
      <div class="lg:pl-4">
        <div class="card p-6 shadow-lift sm:p-8">
          <h2 class="font-display text-xl font-semibold text-ivory">Speak to our finance team</h2>
          <p class="mt-1.5 text-sm text-mist">Share a few details and we’ll find the right plan for you.</p>
          <div class="mt-6"><LeadForm fields={finance.formFields} submitLabel="Request finance" formName="finance" /></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-ink py-20 sm:py-28">
    <div class="lux-wide grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:gap-16">
      <div>
        <p class="eyebrow mb-4" data-reveal>Benefits of financing with GTA Cars</p>
        <h2 class="display-2 text-ivory" data-reveal>Bank-approved, handled in-house.</h2>
        <p class="mt-6 text-sm leading-relaxed text-faint" data-reveal>{finance.note}</p>
      </div>
      <ul class="grid gap-4 sm:grid-cols-2 [&>li:last-child]:sm:col-span-2">
        {finance.benefits.map((b, i) => (
          <li class="card flex items-start gap-3 p-5 text-sm leading-relaxed text-ivory/90" data-reveal data-delay={i * 50}>
            <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-gold/15 text-gold"><Check class="h-3 w-3" /></span>{b}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="border-t border-ivory/10 bg-coal py-24 text-center sm:py-28">
    <div class="lux-narrow">
      <p class="eyebrow mb-5" data-reveal>Creating a 5-Star Customer Experience</p>
      <h2 class="display-2 text-ivory" data-reveal>{letsTalk.body}</h2>
      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row" data-reveal>
        <a href="/contact" class="btn-gold px-8 py-4">Contact us <ArrowRight class="h-4 w-4" /></a>
        <a href={contact.whatsapp} target="_blank" rel="noopener" class="btn-primary px-8 py-4"><MessageCircle class="h-4 w-4" /> WhatsApp</a>
      </div>
    </div>
  </section>
</Layout>
