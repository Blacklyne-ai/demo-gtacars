---
import { ArrowRight, Tag, ShieldCheck, Clock, Banknote } from '@lucide/astro';
import { contact } from '../data/site';

interface Props { image: string; alt: string }
const { image, alt } = Astro.props;
---
<section class="band-dark grain relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden">
  <!-- Cinematic darkened car still -->
  <div class="absolute inset-0 -z-10">
    <img src={image} alt={alt} width="1400" height="1000" fetchpriority="high" decoding="async"
      class="h-full w-full object-cover object-[72%_center] sm:object-[78%_center] [filter:brightness(0.6)_contrast(1.05)_saturate(0.9)]" />
    <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/75 to-ink/10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/25 to-ink/45"></div>
    <!-- subtle gold vignette to anchor the eye -->
    <div class="absolute inset-0 [background:radial-gradient(120%_80%_at_15%_50%,transparent_55%,rgb(10_10_11/0.6))]"></div>
  </div>

  <div class="lux-wide w-full pb-20 pt-[calc(var(--nav-h)+3rem)] sm:pb-28">
    <div class="max-w-2xl">
      <p class="eyebrow mb-5 text-shadow-cine">GTA Cars · Dubai</p>
      <h1 class="display-1 text-ivory text-shadow-cine">
        Buy. Sell.<br />All under one roof.
      </h1>
      <p class="mt-7 max-w-xl text-lg leading-relaxed text-ivory/85 text-shadow-cine">
        Dubai’s leading dealership for quality pre-owned cars. Browse an inspected
        showroom, or sell us yours — fair, friendly and efficient, with no hidden fees.
      </p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a href="/our-cars" class="btn-gold px-8 py-4 text-sm">Browse our cars <ArrowRight class="h-4 w-4" /></a>
        <a href="/sell-your-car" class="btn-primary px-8 py-4 text-sm"><Tag class="h-4 w-4" /> Sell your car</a>
      </div>

      <!-- Trust strip -->
      <ul class="mt-12 flex flex-wrap gap-x-7 gap-y-3 text-[0.78rem] text-ivory/75">
        <li class="inline-flex items-center gap-2"><ShieldCheck class="h-4 w-4 text-gold" /> No hidden fees</li>
        <li class="inline-flex items-center gap-2"><Banknote class="h-4 w-4 text-gold" /> Finance &amp; part-exchange</li>
        <li class="inline-flex items-center gap-2"><Clock class="h-4 w-4 text-gold" /> {contact.hours}</li>
      </ul>
    </div>
  </div>

  <!-- scroll cue -->
  <a href="#sell" aria-label="Scroll to sell your car" class="scroll-cue absolute bottom-6 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-ivory/50 transition-colors hover:text-gold sm:flex">
    <span class="flex h-9 w-5 items-start justify-center rounded-full border border-ivory/30 pt-1.5">
      <span class="h-1.5 w-1 rounded-full bg-gold"></span>
    </span>
  </a>

  <!-- bottom hairline to anchor -->
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
</section>
