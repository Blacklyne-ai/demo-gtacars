---
import { ArrowRight, Tag, ShieldCheck, Clock, Banknote } from '@lucide/astro';
import { contact } from '../data/site';

interface Props { image: string; alt: string }
const { image, alt } = Astro.props;
---
<!-- Sticky-pin cinematic hero. On desktop the wrap is 200vh tall; the inner panel
     pins (CSS sticky, Lenis-friendly) and GSAP scrubs the car scale, draws the
     gold line, and parallaxes the content out. H1 is painted immediately
     (transform-only intro) → LCP-safe. Mobile/reduced-motion = static. -->
<div data-hero-wrap class="band-dark relative lg:h-[200vh]">
  <section data-hero-pin class="grain relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden lg:sticky lg:top-0 lg:h-screen">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <img data-hero-img src={image} alt={alt} width="1600" height="1000" fetchpriority="high" decoding="async"
        class="h-full w-full scale-[1.05] object-cover object-[72%_center] [filter:brightness(0.6)_contrast(1.05)_saturate(0.92)] will-change-transform sm:object-[78%_center]" />
      <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/75 to-ink/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/25 to-ink/45"></div>
      <div class="absolute inset-0 [background:radial-gradient(120%_85%_at_12%_55%,transparent_50%,rgb(8_8_9/0.7))]"></div>
    </div>

    <!-- Gold guide line that draws on scroll -->
    <div data-hero-line class="absolute left-5 top-0 hidden h-full w-px origin-top scale-y-0 bg-gradient-to-b from-gold/0 via-gold/70 to-gold/0 sm:left-10 lg:block lg:left-14"></div>

    <div class="lux-wide w-full pb-20 pt-[calc(var(--nav-h)+3rem)] sm:pb-28">
      <div data-hero-content class="max-w-2xl will-change-transform">
        <p data-hero-fade class="eyebrow mb-5 text-gold text-shadow-cine">GTA Cars · Dubai</p>
        <h1 class="display-1 text-ivory text-shadow-cine">
          <span class="block overflow-hidden"><span data-hero-h1 class="block">Buy. Sell.</span></span>
          <span class="h1-line-2 block overflow-hidden"><span data-hero-h1 class="block">All under one roof.</span></span>
        </h1>
        <p data-hero-fade class="mt-7 max-w-xl text-lg leading-relaxed text-ivory/85 text-shadow-cine">
          Dubai’s leading dealership for quality pre-owned cars. Browse an inspected
          showroom, or sell us yours — fair, friendly and efficient, with no hidden fees.
        </p>

        <div data-hero-fade class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a href="/our-cars" class="btn-gold px-8 py-4 text-sm">Browse our cars <ArrowRight class="h-4 w-4" /></a>
          <a href="/sell-your-car" class="btn-primary px-8 py-4 text-sm"><Tag class="h-4 w-4" /> Sell your car</a>
        </div>

        <ul data-hero-fade class="mt-12 flex flex-wrap gap-x-7 gap-y-3 text-[0.78rem] text-ivory/75">
          <li class="inline-flex items-center gap-2"><ShieldCheck class="h-4 w-4 text-gold" /> No hidden fees</li>
          <li class="inline-flex items-center gap-2"><Banknote class="h-4 w-4 text-gold" /> Finance &amp; part-exchange</li>
          <li class="inline-flex items-center gap-2"><Clock class="h-4 w-4 text-gold" /> {contact.hours}</li>
        </ul>
      </div>
    </div>

    <!-- scroll cue -->
    <a href="#sell" aria-label="Scroll" class="scroll-cue absolute bottom-6 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-2 text-ivory/50 transition-colors hover:text-gold lg:flex">
      <span class="text-[0.6rem] uppercase tracking-[0.3em]">Scroll</span>
      <span class="flex h-9 w-5 items-start justify-center rounded-full border border-ivory/30 pt-1.5"><span class="h-1.5 w-1 rounded-full bg-gold"></span></span>
    </a>

    <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-gold/30 to-transparent"></div>
  </section>
</div>
