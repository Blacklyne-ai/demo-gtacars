---
import { ArrowRight, Tag } from '@lucide/astro';
interface Props { image: string; alt: string }
const { image, alt } = Astro.props;
---
<!-- Editorial-luxury hero: cinematic Dubai skyline, elegant serif headline,
     gentle ken-burns. Headline rises line-by-line on load (CSS, LCP-safe). -->
<section class="band-dark grain relative isolate flex min-h-[100svh] flex-col justify-end overflow-hidden">
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <img src={image} alt={alt} width="1920" height="1200" fetchpriority="high" decoding="async"
      class="h-full w-full origin-center animate-kenburns object-cover object-center [filter:saturate(1.02)]" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/45 to-ink/5"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-ink/80 via-ink/20 to-transparent"></div>
  </div>

  <div class="lux-wide w-full pb-24 pt-[calc(var(--nav-h)+2rem)] sm:pb-28">
    <div data-hero-content class="max-w-3xl">
      <p data-hero-fade class="mb-6 text-[0.7rem] font-semibold uppercase tracking-[0.34em] text-gold text-shadow-cine">Dubai · Buy · Sell · Consign</p>
      <h1 class="display-1 text-ivory text-shadow-cine">
        <span class="block overflow-hidden"><span data-hero-h1 class="block">Buy, sell,</span></span>
        <span class="h1-line-2 block overflow-hidden"><span data-hero-h1 class="block">all under one roof.</span></span>
      </h1>
      <p data-hero-fade class="mt-8 max-w-xl text-lg leading-relaxed text-ivory/85 text-shadow-cine">
        Dubai’s leading dealership for quality pre-owned cars. Browse an inspected
        showroom, or sell us yours — fair, friendly and efficient, with no hidden fees.
      </p>
      <div data-hero-fade class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a href="/our-cars" class="btn-gold px-8 py-4 text-sm">Browse the cars <ArrowRight class="h-4 w-4" /></a>
        <a href="/sell-your-car" class="btn-primary px-8 py-4 text-sm"><Tag class="h-4 w-4" /> Sell your car</a>
      </div>
    </div>
  </div>

  <!-- corner label + scroll cue -->
  <div class="lux-wide pointer-events-none absolute inset-x-0 bottom-6 hidden items-center justify-between sm:flex">
    <span class="text-[0.62rem] uppercase tracking-[0.32em] text-ivory/55">Quality pre-owned · Dubai</span>
    <a href="#fleet" aria-label="Scroll" class="scroll-cue pointer-events-auto flex flex-col items-center gap-2 text-ivory/55 transition-colors hover:text-gold">
      <span class="flex h-9 w-5 items-start justify-center rounded-full border border-ivory/30 pt-1.5"><span class="h-1.5 w-1 rounded-full bg-gold"></span></span>
    </a>
  </div>
</section>
