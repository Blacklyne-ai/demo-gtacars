---
// Dark cinematic image band — real published figures from gtacars.ae.
// Numbers count up tied to scroll (driven in Layout). Tonal relief + imagery.
import { ArrowRight } from '@lucide/astro';
const img = '/images/cars/2026-land-rover-defender-110-p525-v8-5-years-lr-warranty-service-pack-fully-loaded-gcc/00.webp';
const stats = [
  { to: 5, suffix: '', label: 'Showrooms' },
  { to: 50, suffix: '+', label: 'Car Makes' },
  { to: 800, suffix: '+', label: 'Cars in stock' },
  { to: 10000, suffix: '+', label: 'Happy clients' },
];
---
<section class="band-dark grain relative isolate overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <img data-parallax src={img} alt="" aria-hidden="true" width="1400" height="800" loading="lazy" decoding="async"
      class="h-full w-full object-cover object-[60%_center] [filter:brightness(0.38)_saturate(0.85)]" />
    <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/80 to-ink/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-transparent to-ink/70"></div>
  </div>

  <div class="lux-wide py-24 sm:py-32">
    <div class="max-w-xl">
      <p class="eyebrow mb-4" data-reveal>One of the UAE’s fastest-growing showrooms</p>
      <h2 class="display-2 text-ivory" data-lines>Trusted by thousands across the Emirates.</h2>
    </div>

    <div class="mt-14 grid grid-cols-2 gap-x-8 gap-y-12 lg:grid-cols-4">
      {stats.map((s, i) => (
        <div data-reveal data-delay={i * 70}>
          <p class="price-aed font-display text-[clamp(2.6rem,5vw,4.2rem)] font-bold leading-none text-gold">
            <span data-counter data-to={s.to}>0</span>{s.suffix}
          </p>
          <div class="mt-3 h-px w-10 bg-gold/50"></div>
          <p class="mt-3 text-[0.8rem] uppercase tracking-[0.18em] text-mist">{s.label}</p>
        </div>
      ))}
    </div>

    <div class="mt-14" data-reveal>
      <a href="/about" class="link-arrow">More about GTA Cars <ArrowRight class="h-4 w-4" /></a>
    </div>
  </div>
</section>
