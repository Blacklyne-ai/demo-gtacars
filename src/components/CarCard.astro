---
import { Heart, Gauge, Cog, Fuel } from '@lucide/astro';
import { fmtAED, fmtKm, type Car } from '../lib/cars';

interface Props { car: Car; eager?: boolean }
const { car, eager = false } = Astro.props;
const href = `/our-cars/${car.slug}`;
const km = fmtKm(car.specs.mileageKm);
---
<article
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-ivory/10 bg-graphite transition-all duration-500 ease-luxe hover:border-gold/40 hover:shadow-lift"
  data-car
  data-brand={car.brand}
  data-body={car.bodyType}
  data-year={car.year ?? ''}
  data-price={car.priceAed ?? ''}
  data-km={car.specs.mileageKm ?? ''}
  data-name={car.name.toLowerCase()}
>
  <div class="relative block aspect-[4/3] overflow-hidden bg-coal">
    <img
      src={car.cardImage}
      alt={car.name}
      width="760" height="540"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-[1.2s] ease-luxe group-hover:scale-[1.06]"
    />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/70 via-transparent to-transparent"></div>
    {car.sold && (
      <span class="absolute left-4 top-4 rounded-full bg-[rgb(12,12,13)]/85 px-3 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-gold-lite ring-1 ring-gold/40 backdrop-blur">Sold</span>
    )}
    {car.year && (
      <span class="absolute bottom-3 left-4 rounded-full bg-ink/55 px-2.5 py-1 text-[0.66rem] font-semibold uppercase tracking-[0.14em] text-ivory backdrop-blur">{car.year}</span>
    )}
  </div>

  <button data-wish data-id={car.slug}
    class="absolute right-3.5 top-3.5 z-10 inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink/55 text-ivory/85 backdrop-blur transition-colors hover:text-gold"
    aria-label={`Save ${car.name}`} aria-pressed="false">
    <Heart class="h-[18px] w-[18px]" />
  </button>

  <div class="flex flex-1 flex-col p-5">
    <p class="text-[0.66rem] font-semibold uppercase tracking-[0.2em] text-gold-deep">{car.brand}</p>
    <h3 class="mt-1.5 font-display text-lg font-semibold leading-snug text-ivory">
      <a href={href} class="after:absolute after:inset-0 after:content-['']">{car.name}</a>
    </h3>

    <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1.5 text-[0.78rem] text-mist">
      {km && <span class="inline-flex items-center gap-1.5"><Gauge class="h-3.5 w-3.5 text-faint" />{km}</span>}
      {car.specs.transmission && <span class="inline-flex items-center gap-1.5"><Cog class="h-3.5 w-3.5 text-faint" />{car.specs.transmission}</span>}
      {car.bodyType && car.bodyType !== 'Other' && <span class="inline-flex items-center gap-1.5"><Fuel class="h-3.5 w-3.5 text-faint" />{car.bodyType}</span>}
    </div>

    <div class="mt-5 flex items-end justify-between border-t border-ivory/8 pt-4">
      <div>
        <p class="price-aed font-display text-xl font-bold text-ivory">{fmtAED(car.priceAed)}</p>
        {car.monthlyAed && <p class="mt-0.5 text-[0.72rem] text-mist">from AED {car.monthlyAed.toLocaleString('en-US')}/month</p>}
      </div>
      <span class="relative z-10 text-[0.72rem] font-medium uppercase tracking-[0.14em] text-gold-deep transition-colors group-hover:text-gold">View →</span>
    </div>
  </div>
</article>
