---
import { Heart, ArrowUpRight } from '@lucide/astro';
import { fmtAED, fmtKm, type Car } from '../lib/cars';

interface Props { car: Car; eager?: boolean }
const { car, eager = false } = Astro.props;
const href = `/our-cars/${car.slug}`;
const km = fmtKm(car.specs.mileageKm);
const meta = [km, car.specs.transmission, car.bodyType && car.bodyType !== 'Other' ? car.bodyType : null].filter(Boolean);
---
<article
  class="group relative flex flex-col"
  data-car
  data-brand={car.brand}
  data-body={car.bodyType}
  data-year={car.year ?? ''}
  data-price={car.priceAed ?? ''}
  data-km={car.specs.mileageKm ?? ''}
  data-name={car.name.toLowerCase()}
>
  <div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-coal">
    <img
      src={car.cardImage}
      alt={car.name}
      width="760" height="540"
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-[1.3s] ease-luxe group-hover:scale-[1.05]"
    />
    {car.sold && (
      <span class="absolute left-3 top-3 rounded-full bg-[rgb(12,12,13)]/85 px-3 py-1 text-[0.6rem] font-semibold uppercase tracking-[0.18em] text-gold-lite backdrop-blur">Sold</span>
    )}

    <button data-wish data-id={car.slug}
      class="absolute right-3 top-3 z-10 inline-flex h-9 w-9 items-center justify-center rounded-full bg-graphite/90 text-ivory/70 shadow-soft backdrop-blur transition-colors hover:text-gold-deep"
      aria-label={`Save ${car.name}`} aria-pressed="false">
      <Heart class="h-[17px] w-[17px]" />
    </button>

    <!-- view affordance (echoes the reference card) -->
    <span class="absolute bottom-3 right-3 inline-flex h-10 w-10 translate-y-1 items-center justify-center rounded-full bg-gold text-[rgb(20,17,8)] opacity-0 shadow-soft transition-all duration-500 ease-luxe group-hover:translate-y-0 group-hover:opacity-100">
      <ArrowUpRight class="h-4 w-4" />
    </span>
  </div>

  <div class="flex flex-1 flex-col px-1 pt-4">
    <div class="flex items-baseline justify-between gap-3">
      <p class="text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-gold-deep">{car.brand}</p>
      {car.year && <p class="text-[0.62rem] uppercase tracking-[0.16em] text-faint">{car.year}</p>}
    </div>
    <h3 class="mt-1.5 font-display text-[1.35rem] font-medium leading-tight text-ivory">
      <a href={href} class="after:absolute after:inset-0 after:content-['']">{car.name}</a>
    </h3>

    <p class="mt-2.5 text-[0.78rem] text-mist">{meta.join('  ·  ')}</p>

    <div class="mt-4 flex items-baseline gap-2 border-t border-ivory/10 pt-3.5">
      <p class="price-aed font-display text-[1.4rem] font-semibold text-ivory">{fmtAED(car.priceAed)}</p>
      {car.monthlyAed && <p class="text-[0.72rem] text-faint">· from AED {car.monthlyAed.toLocaleString('en-US')}/mo</p>}
    </div>
  </div>
</article>
